// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  userId       String?     @unique
  email        String      @unique
  name         String?
  password     String
  roleId       String?     @map("role_id")
  role         Role?       @relation(fields: [roleId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  inactive     Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Relations
  customers      Customer[]
  contacts       Contact[]
  projects       Project[]
  tasks          Task[]
  leads          Lead[]
  opportunities  Opportunity[]
  quotes         Quote[]
  salesOrders    SalesOrder[]
  invoices       Invoice[]
  requisitions   Requisition[]
  purchaseOrders PurchaseOrder[]
  creditMemos    CreditMemo[]
  billCredits    BillCredit[]
  bills          Bill[]
  journalEntries JournalEntry[]
  employee       Employee?

  @@index([roleId])
  @@index([departmentId])
  @@map("users")
}

model Customer {
  id         String   @id @default(cuid())
  customerId String?  @unique
  name           String
  email          String?
  phone          String?
  address        String?
  industry       String?
  entityId       String?
  currencyId     String?
  inactive       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  contacts      Contact[]
  leads         Lead[]
  opportunities Opportunity[]
  quotes        Quote[]
  salesOrders   SalesOrder[]
  invoices      Invoice[]
  creditMemos   CreditMemo[]
  entity        Entity?       @relation(fields: [entityId], references: [id])
  currency      Currency?     @relation(fields: [currencyId], references: [id])

  @@index([userId])
  @@index([entityId])
  @@index([currencyId])
  @@map("customers")
}

model Contact {
  id            String   @id @default(cuid())
  contactNumber String?  @unique
  firstName     String
  lastName      String
  email         String?
  phone         String?
  address       String?
  position      String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  leads      Lead[]
  userId     String
  user       User     @relation(fields: [userId], references: [id])

  @@index([customerId])
  @@index([userId])
  @@map("contacts")
}



model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  status      String    @default("planning")
  inactive    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id])
  tasks  Task[]

  @@index([userId])
  @@map("projects")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("todo")
  priority    String    @default("medium")
  dueDate     DateTime?
  inactive    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@index([userId])
  @@map("tasks")
}

model Vendor {
  id           String   @id @default(cuid())
  vendorNumber String?  @unique
  name         String
  email        String?
  phone        String?
  address      String?
  taxId        String?
  entityId     String?
  currencyId   String?
  inactive     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  requisitions   Requisition[]
  purchaseOrders PurchaseOrder[]
  bills          Bill[]
  billCredits    BillCredit[]
  entity         Entity?         @relation(fields: [entityId], references: [id])
  currency       Currency?       @relation(fields: [currencyId], references: [id])

  @@index([entityId])
  @@index([currencyId])
  @@map("vendors")
}

model Department {
  id        String   @id @default(cuid())
  name      String
  departmentId String @unique @map("code")
  description String?
  division  String?
  entityId  String?
  active    Boolean  @default(true)
  managerId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users        User[]
  requisitions Requisition[]
  employees    Employee[]
  entity       Entity? @relation(fields: [entityId], references: [id])

  @@index([entityId])
  @@map("departments")
}



model Location {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String?
  inactive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("locations")
}

model CostCenter {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  inactive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cost_centers")
}

model ChartOfAccounts {
  id                            String   @id @default(cuid())
  accountId                     String   @unique @map("accountNumber")
  name                          String
  description                   String?
  accountType                   String // List/select value (Asset, Liability, Equity, Revenue, Expense, etc.)
  inventory                     Boolean  @default(false)
  revalueOpenBalance            Boolean  @default(false)
  eliminateIntercoTransactions  Boolean  @default(false)
  summary                       Boolean  @default(false)
  parentSubsidiaryId            String?
  includeChildren               Boolean  @default(false)
  category                      String?
  active                        Boolean  @default(true)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  // Relations
  journalEntryLineItems  JournalEntryLineItem[]
  parentSubsidiary       Entity?                    @relation("ChartOfAccountParentSubsidiary", fields: [parentSubsidiaryId], references: [id])
  subsidiaryAssignments  ChartOfAccountSubsidiary[]

  @@index([parentSubsidiaryId])

  @@map("chart_of_accounts")
}

model ChartOfAccountSubsidiary {
  id               String   @id @default(cuid())
  chartOfAccountId String
  subsidiaryId     String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  chartOfAccount ChartOfAccounts @relation(fields: [chartOfAccountId], references: [id], onDelete: Cascade)
  subsidiary     Entity          @relation("ChartOfAccountSubsidiaryAssignment", fields: [subsidiaryId], references: [id], onDelete: Cascade)

  @@unique([chartOfAccountId, subsidiaryId])
  @@index([subsidiaryId])
  @@map("chart_of_account_subsidiaries")
}

model CustomFieldDefinition {
  id           String   @id @default(cuid())
  name         String
  label        String
  type         String // text, number, date, select, etc.
  required     Boolean  @default(false)
  defaultValue String?
  options      String? // JSON for select options
  entityType   String // Customer, Order, etc.
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  values CustomFieldValue[]

  @@map("custom_field_definitions")
}

model CustomFieldValue {
  id         String   @id @default(cuid())
  fieldId    String
  recordId   String // ID of the record
  entityType String // Type of entity
  value      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  field CustomFieldDefinition @relation(fields: [fieldId], references: [id])

  @@index([fieldId])
  @@index([entityType, recordId])
  @@map("custom_field_values")
}

model CustomTransactionType {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  entityType  String // Quote, Order, Invoice, etc.
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("custom_transaction_types")
}

model Lead {
  id              String    @id @default(cuid())
  leadNumber      String?   @unique
  firstName       String?
  lastName        String?
  email           String?
  phone           String?
  company         String?
  title           String?
  website         String?
  industry        String?
  address         String?
  status          String    @default("new")
  source          String?
  rating          String?
  notes           String?
  expectedValue   Float?
  qualifiedAt     DateTime?
  convertedAt     DateTime?
  lastContactedAt DateTime?
  inactive        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  entityId      String?
  entity        Entity?      @relation(fields: [entityId], references: [id])
  currencyId    String?
  currency      Currency?    @relation(fields: [currencyId], references: [id])
  customerId    String?
  customer      Customer?    @relation(fields: [customerId], references: [id])
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([entityId])
  @@index([currencyId])
  @@index([customerId])
  @@index([contactId])
  @@index([opportunityId])
  @@map("leads")
}

model Opportunity {
  id                String    @id @default(cuid())
  opportunityNumber String?   @unique
  name              String
  amount            Float?
  stage             String    @default("prospecting")
  closeDate         DateTime?
  probability       Float?
  entityId          String?
  currencyId        String?
  inactive          Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id])
  leads      Lead[]
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  quote      Quote?
  lineItems  OpportunityLineItem[]
  entity     Entity?   @relation(fields: [entityId], references: [id])
  currency   Currency? @relation(fields: [currencyId], references: [id])

  @@index([customerId])
  @@index([userId])
  @@index([entityId])
  @@index([currencyId])
  @@map("opportunities")
}

model OpportunityLineItem {
  id            String      @id @default(cuid())
  description   String
  quantity      Int         @default(1)
  unitPrice     Float       @default(0)
  lineTotal     Float       @default(0)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  itemId        String?
  item          Item?       @relation(fields: [itemId], references: [id])

  @@index([opportunityId])
  @@index([itemId])
  @@map("opportunity_line_items")
}

model Quote {
  id         String    @id @default(cuid())
  number     String    @unique
  status     String    @default("draft")
  total      Float
  validUntil DateTime?
  notes      String?
  entityId   String?
  currencyId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  customerId    String
  customer      Customer     @relation(fields: [customerId], references: [id])
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  opportunityId String?      @unique
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  salesOrder    SalesOrder?
  lineItems     QuoteLineItem[]
  entity        Entity?      @relation(fields: [entityId], references: [id])
  currency      Currency?    @relation(fields: [currencyId], references: [id])

  @@index([customerId])
  @@index([userId])
  @@index([entityId])
  @@index([currencyId])
  @@map("quotes")
}

model SalesOrder {
  id         String   @id @default(cuid())
  number     String   @unique
  status     String   @default("draft")
  total      Float
  entityId   String?
  currencyId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id])
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  quoteId    String?   @unique
  quote      Quote?    @relation(fields: [quoteId], references: [id])
  invoices   Invoice[]
  lineItems  SalesOrderLineItem[]
  entity     Entity?   @relation(fields: [entityId], references: [id])
  currency   Currency? @relation(fields: [currencyId], references: [id])

  @@index([customerId])
  @@index([userId])
  @@index([entityId])
  @@index([currencyId])
  @@map("sales_orders")
}

model Invoice {
  id         String    @id @default(cuid())
  number     String    @unique
  status     String    @default("draft")
  total      Float
  dueDate    DateTime?
  paidDate   DateTime?
  entityId   String?
  currencyId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  customerId   String
  customer     Customer      @relation(fields: [customerId], references: [id])
  salesOrderId String?
  salesOrder   SalesOrder?   @relation(fields: [salesOrderId], references: [id])
  userId       String?
  user         User?         @relation(fields: [userId], references: [id])
  cashReceipts CashReceipt[]
  lineItems    InvoiceLineItem[]
  creditMemos  CreditMemo[]
  entity       Entity?       @relation(fields: [entityId], references: [id])
  currency     Currency?     @relation(fields: [currencyId], references: [id])

  @@index([customerId])
  @@index([salesOrderId])
  @@index([userId])
  @@index([entityId])
  @@index([currencyId])
  @@map("invoices")
}

model CashReceipt {
  id        String   @id @default(cuid())
  amount    Float
  date      DateTime
  method    String // check, wire, etc.
  reference String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("cash_receipts")
}

model Requisition {
  id            String    @id @default(cuid())
  number        String    @unique
  status        String    @default("draft")
  title         String?
  description   String?
  priority      String    @default("medium")
  neededByDate  DateTime?
  notes         String?
  total         Float     @default(0)
  entityId      String?
  currencyId    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  userId        String
  user          User                    @relation(fields: [userId], references: [id])
  departmentId  String?
  department    Department?             @relation(fields: [departmentId], references: [id])
  vendorId      String?
  vendor        Vendor?                 @relation(fields: [vendorId], references: [id])
  entity        Entity?                 @relation(fields: [entityId], references: [id])
  currency      Currency?               @relation(fields: [currencyId], references: [id])
  lineItems     RequisitionLineItem[]
  purchaseOrder PurchaseOrder?

  @@index([userId])
  @@index([departmentId])
  @@index([vendorId])
  @@index([entityId])
  @@index([currencyId])
  @@index([status])
  @@map("requisitions")
}

model RequisitionLineItem {
  id            String      @id @default(cuid())
  description   String
  quantity      Int         @default(1)
  unitPrice     Float       @default(0)
  lineTotal     Float       @default(0)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  requisitionId String
  requisition   Requisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  itemId        String?
  item          Item?       @relation(fields: [itemId], references: [id])

  @@index([requisitionId])
  @@index([itemId])
  @@map("requisition_line_items")
}

model PurchaseOrder {
  id         String   @id @default(cuid())
  number     String   @unique
  status     String   @default("draft")
  total      Float
  entityId   String?
  currencyId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  vendorId      String
  vendor        Vendor                  @relation(fields: [vendorId], references: [id])
  userId        String
  user          User                    @relation(fields: [userId], references: [id])
  requisitionId String?                 @unique
  requisition   Requisition?            @relation(fields: [requisitionId], references: [id])
  lineItems     PurchaseOrderLineItem[]
  receipts      Receipt[]
  bills         Bill[]
  entity        Entity?                 @relation(fields: [entityId], references: [id])
  currency      Currency?               @relation(fields: [currencyId], references: [id])

  @@index([vendorId])
  @@index([userId])
  @@index([entityId])
  @@index([currencyId])
  @@map("purchase_orders")
}

model PurchaseOrderLineItem {
  id          String   @id @default(cuid())
  description String
  quantity    Int
  unitPrice   Float
  lineTotal   Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  itemId          String?
  item            Item?         @relation(fields: [itemId], references: [id])

  @@index([purchaseOrderId])
  @@index([itemId])
  @@map("purchase_order_line_items")
}

model QuoteLineItem {
  id          String   @id @default(cuid())
  description String
  quantity    Int      @default(1)
  unitPrice   Float    @default(0)
  lineTotal   Float    @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  itemId  String?
  item    Item?  @relation(fields: [itemId], references: [id])

  @@index([quoteId])
  @@index([itemId])
  @@map("quote_line_items")
}

model SalesOrderLineItem {
  id          String   @id @default(cuid())
  description String
  quantity    Int      @default(1)
  unitPrice   Float    @default(0)
  lineTotal   Float    @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  itemId       String?
  item         Item?      @relation(fields: [itemId], references: [id])

  @@index([salesOrderId])
  @@index([itemId])
  @@map("sales_order_line_items")
}

model InvoiceLineItem {
  id          String   @id @default(cuid())
  description String
  quantity    Int      @default(1)
  unitPrice   Float    @default(0)
  lineTotal   Float    @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  itemId    String?
  item      Item?   @relation(fields: [itemId], references: [id])

  @@index([invoiceId])
  @@index([itemId])
  @@map("invoice_line_items")
}

model BillLineItem {
  id          String   @id @default(cuid())
  description String
  quantity    Int      @default(1)
  unitPrice   Float    @default(0)
  lineTotal   Float    @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  billId String
  bill   Bill   @relation(fields: [billId], references: [id], onDelete: Cascade)
  itemId String?
  item   Item?  @relation(fields: [itemId], references: [id])

  @@index([billId])
  @@index([itemId])
  @@map("bill_line_items")
}

model CreditMemo {
  id         String    @id @default(cuid())
  number     String    @unique
  status     String    @default("draft")
  total      Float
  date       DateTime  @default(now())
  reason     String?
  notes      String?
  entityId   String?
  currencyId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  customerId String
  customer   Customer            @relation(fields: [customerId], references: [id])
  invoiceId  String?
  invoice    Invoice?            @relation(fields: [invoiceId], references: [id])
  userId     String
  user       User                @relation(fields: [userId], references: [id])
  lineItems  CreditMemoLineItem[]
  entity     Entity?             @relation(fields: [entityId], references: [id])
  currency   Currency?           @relation(fields: [currencyId], references: [id])

  @@index([customerId])
  @@index([invoiceId])
  @@index([userId])
  @@index([entityId])
  @@index([currencyId])
  @@map("credit_memos")
}

model CreditMemoLineItem {
  id          String   @id @default(cuid())
  description String
  quantity    Int      @default(1)
  unitPrice   Float    @default(0)
  lineTotal   Float    @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creditMemoId String
  creditMemo   CreditMemo @relation(fields: [creditMemoId], references: [id], onDelete: Cascade)
  itemId       String?
  item         Item?      @relation(fields: [itemId], references: [id])

  @@index([creditMemoId])
  @@index([itemId])
  @@map("credit_memo_line_items")
}

model BillCredit {
  id         String    @id @default(cuid())
  number     String    @unique
  status     String    @default("draft")
  total      Float
  date       DateTime  @default(now())
  reason     String?
  notes      String?
  entityId   String?
  currencyId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  vendorId  String
  vendor    Vendor               @relation(fields: [vendorId], references: [id])
  billId    String?
  bill      Bill?                @relation(fields: [billId], references: [id])
  userId    String
  user      User                 @relation(fields: [userId], references: [id])
  lineItems BillCreditLineItem[]
  entity    Entity?              @relation(fields: [entityId], references: [id])
  currency  Currency?            @relation(fields: [currencyId], references: [id])

  @@index([vendorId])
  @@index([billId])
  @@index([userId])
  @@index([entityId])
  @@index([currencyId])
  @@map("bill_credits")
}

model BillCreditLineItem {
  id          String   @id @default(cuid())
  description String
  quantity    Int      @default(1)
  unitPrice   Float    @default(0)
  lineTotal   Float    @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  billCreditId String
  billCredit   BillCredit @relation(fields: [billCreditId], references: [id], onDelete: Cascade)
  itemId       String?
  item         Item?      @relation(fields: [itemId], references: [id])

  @@index([billCreditId])
  @@index([itemId])
  @@map("bill_credit_line_items")
}

model JournalEntryLineItem {
  id          String   @id @default(cuid())
  description String?
  debit       Float    @default(0)
  credit      Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  journalEntryId String
  journalEntry   JournalEntry    @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        ChartOfAccounts @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_entry_line_items")
}

model Activity {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  summary    String
  userId     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("activities")
}

model Receipt {
  id        String   @id @default(cuid())
  quantity  Int
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@index([purchaseOrderId])
  @@map("receipts")
}

model Bill {
  id         String    @id @default(cuid())
  number     String    @unique
  vendorId   String
  total      Float     @map("amount")
  date       DateTime
  dueDate    DateTime?
  status     String    @default("received")
  notes      String?
  ocrData    String? // JSON
  entityId   String?
  currencyId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  vendor          Vendor         @relation(fields: [vendorId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  userId          String?
  user            User?          @relation(fields: [userId], references: [id])
  lineItems       BillLineItem[]
  billCredits     BillCredit[]
  entity          Entity?        @relation(fields: [entityId], references: [id])
  currency        Currency?      @relation(fields: [currencyId], references: [id])

  @@index([vendorId])
  @@index([purchaseOrderId])
  @@index([userId])
  @@index([status])
  @@index([entityId])
  @@index([currencyId])
  @@map("bills")
}

model JournalEntry {
  id          String   @id @default(cuid())
  number      String   @unique
  date        DateTime
  description String?
  status      String   @default("draft")
  total       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  entityId   String?
  entity     Entity?              @relation(fields: [entityId], references: [id])
  currencyId String?
  currency   Currency?            @relation(fields: [currencyId], references: [id])
  userId     String?
  user       User?                @relation(fields: [userId], references: [id])
  lineItems  JournalEntryLineItem[]

  @@index([entityId])
  @@index([currencyId])
  @@index([userId])
  @@map("journal_entries")
}

model AccountingPeriod {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  closed    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("accounting_periods")
}

model Attachment {
  id         String   @id @default(cuid())
  name       String
  url        String
  type       String
  entityId   String
  entityType String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([entityType, entityId])
  @@map("attachments")
}

model IntegrationLog {
  id          String   @id @default(cuid())
  integration String
  action      String
  status      String
  message     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("integration_logs")
}

model ApprovalRecord {
  id         String   @id @default(cuid())
  entityId   String
  entityType String
  approverId String
  status     String
  comments   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([entityType, entityId])
  @@map("approval_records")
}

model Role {
  id          String   @id @default(cuid())
  roleId      String   @unique
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users User[]

  @@map("roles")
}

model Currency {
  id         String   @id @default(cuid())
  currencyId String   @unique @map("code")
  name       String
  symbol    String?
  decimals  Int      @default(2)
  isBase    Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  entities       Entity[]        @relation("EntityDefaultCurrency")
  items          Item[]
  customers      Customer[]
  vendors        Vendor[]
  leads          Lead[]
  opportunities  Opportunity[]
  quotes         Quote[]
  salesOrders    SalesOrder[]
  invoices       Invoice[]
  creditMemos    CreditMemo[]
  purchaseOrders PurchaseOrder[]
  bills          Bill[]
  billCredits    BillCredit[]
  requisitions   Requisition[]
  journalEntries JournalEntry[]

  @@map("currencies")
}

model Entity {
  id                 String   @id @default(cuid())
  subsidiaryId       String   @unique @map("code")
  name               String
  legalName          String?
  entityType         String?
  country            String?
  address            String?
  taxId              String?
  registrationNumber String?
  parentEntityId     String?
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  defaultCurrencyId String?
  defaultCurrency   Currency?       @relation("EntityDefaultCurrency", fields: [defaultCurrencyId], references: [id])
  parentEntity      Entity?         @relation("EntityHierarchy", fields: [parentEntityId], references: [id])
  childEntities     Entity[]        @relation("EntityHierarchy")
  departments       Department[]
  employees         Employee[]
  items             Item[]
  customers         Customer[]
  vendors           Vendor[]
  leads             Lead[]
  opportunities     Opportunity[]
  quotes            Quote[]
  salesOrders       SalesOrder[]
  invoices          Invoice[]
  creditMemos       CreditMemo[]
  purchaseOrders    PurchaseOrder[]
  bills             Bill[]
  billCredits       BillCredit[]
  requisitions      Requisition[]
  journalEntries    JournalEntry[]
  chartOfAccountsAsParent      ChartOfAccounts[]          @relation("ChartOfAccountParentSubsidiary")
  chartOfAccountAssignments    ChartOfAccountSubsidiary[] @relation("ChartOfAccountSubsidiaryAssignment")

  @@index([defaultCurrencyId])
  @@index([parentEntityId])
  @@map("subsidiaries")
}

model Item {
  id          String   @id @default(cuid())
  itemId      String?  @unique @map("itemNumber")
  sku         String?  @unique
  name        String
  description String?
  itemType    String   @default("service")
  uom         String? // unit of measure
  listPrice   Float    @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  currencyId             String?
  currency               Currency?               @relation(fields: [currencyId], references: [id])
  entityId               String?
  entity                 Entity?                 @relation(fields: [entityId], references: [id])
  opportunityLineItems   OpportunityLineItem[]
  purchaseOrderLineItems PurchaseOrderLineItem[]
  requisitionLineItems   RequisitionLineItem[]
  quoteLineItems         QuoteLineItem[]
  salesOrderLineItems    SalesOrderLineItem[]
  invoiceLineItems       InvoiceLineItem[]
  billLineItems          BillLineItem[]
  creditMemoLineItems    CreditMemoLineItem[]
  billCreditLineItems    BillCreditLineItem[]

  @@index([currencyId])
  @@index([entityId])
  @@map("items")
}

model Employee {
  id              String    @id @default(cuid())
  employeeId      String?   @unique @map("employeeNumber")
  firstName       String
  lastName        String
  email           String?   @unique
  phone           String?
  title           String?
  active          Boolean   @default(true)
  hireDate        DateTime?
  terminationDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  entityId      String?
  entity        Entity?     @relation(fields: [entityId], references: [id])
  departmentId  String?
  departmentRef Department? @relation(fields: [departmentId], references: [id])
  userId        String?     @unique
  user          User?       @relation(fields: [userId], references: [id])
  managerId     String?
  manager       Employee?   @relation("EmployeeManager", fields: [managerId], references: [id])
  directReports Employee[]  @relation("EmployeeManager")

  @@index([entityId])
  @@index([departmentId])
  @@index([managerId])
  @@map("employees")
}

model CustomerIndustryOption {
  id        String   @id @default(cuid())
  value     String   @unique
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@map("customer_industry_options")
}

model ItemTypeOption {
  id        String   @id @default(cuid())
  value     String   @unique
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@map("item_type_options")
}

model LeadSourceOption {
  id        String   @id @default(cuid())
  value     String   @unique
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@map("lead_source_options")
}

model LeadRatingOption {
  id        String   @id @default(cuid())
  value     String   @unique
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@map("lead_rating_options")
}

model OpportunityStageOption {
  id        String   @id @default(cuid())
  value     String   @unique
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@map("opportunity_stage_options")
}
