// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

model ListOption {
  id        String   @id @default(cuid())
  key       String // e.g. CUST-INDUSTRY
  listId    String // e.g. LIST-CUST-INDUSTRY-0001
  value     String // e.g. Quick Service Restaurant
  label     String // e.g. Quick Service Restaurant
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([listId])
  @@index([key, sortOrder])
  @@map("list_options")
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String      @id @default(cuid())
  userId                  String?     @unique
  email                   String      @unique
  name                    String?
  password                String
  roleId                  String?     @map("role_id")
  role                    Role?       @relation(fields: [roleId], references: [id])
  departmentId            String?
  department              Department? @relation(fields: [departmentId], references: [id])
  inactive                Boolean     @default(false)
  locked                  Boolean     @default(false)
  lockedAt                DateTime?
  lastLoginAt             DateTime?
  passwordChangedAt       DateTime?
  mustChangePassword      Boolean     @default(false)
  failedLoginAttempts     Int         @default(0)
  defaultSubsidiaryId     String?
  defaultSubsidiary       Subsidiary?     @relation("UserDefaultSubsidiary", fields: [defaultSubsidiaryId], references: [id], onDelete: SetNull)
  includeChildren         Boolean     @default(false)
  approvalLimit           Decimal?  @db.Decimal(18, 2)
  approvalCurrencyId      String?
  approvalCurrency        Currency?   @relation("UserApprovalCurrency", fields: [approvalCurrencyId], references: [id], onDelete: SetNull)
  delegatedApproverUserId String?
  delegatedApprover       User?       @relation("UserDelegatedApprover", fields: [delegatedApproverUserId], references: [id], onDelete: SetNull)
  delegatedApproverFor    User[]      @relation("UserDelegatedApprover")
  delegationStartDate     DateTime?
  delegationEndDate       DateTime?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Relations
  subsidiaryAssignments UserSubsidiary[]
  customers             Customer[]
  contacts              Contact[]
  projects              Project[]
  tasks                 Task[]
  leads                 Lead[]
  opportunities         Opportunity[]
  quotes                Quote[]
  salesOrders           SalesOrder[]
  invoices              Invoice[]
  requisitions          Requisition[]
  purchaseOrders        PurchaseOrder[]
  creditMemos           CreditMemo[]
  billCredits           BillCredit[]
  bills                 Bill[]
  journalEntries        JournalEntry[]
  employee              Employee?
  savedListViews        SavedListView[]

  @@index([roleId])
  @@index([departmentId])
  @@index([defaultSubsidiaryId])
  @@index([approvalCurrencyId])
  @@index([delegatedApproverUserId])
  @@map("users")
}

model UserSubsidiary {
  id           String   @id @default(cuid())
  userId       String
  subsidiaryId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  subsidiary Subsidiary @relation(fields: [subsidiaryId], references: [id], onDelete: Cascade)

  @@unique([userId, subsidiaryId])
  @@index([userId])
  @@index([subsidiaryId])
  @@map("user_subsidiaries")
}

model SavedListView {
  id          String   @id @default(cuid())
  userId      String
  tableId     String
  name        String
  columnIds   String
  columnOrder String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tableId, name])
  @@index([userId, tableId])
  @@index([userId, tableId, isDefault])
  @@map("saved_list_views")
}

model Customer {
  id         String   @id @default(cuid())
  customerId String?  @unique
  // Add locale here when customer-facing document formatting expands beyond company-level defaults.
  name       String
  email      String?
  phone      String?
  address    String?
  industry   String?
  subsidiaryId String?
  currencyId String?
  inactive   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  userId                String
  user                  User                   @relation(fields: [userId], references: [id])
  contacts              Contact[]
  leads                 Lead[]
  opportunities         Opportunity[]
  quotes                Quote[]
  salesOrders           SalesOrder[]
  invoices              Invoice[]
  creditMemos           CreditMemo[]
  journalEntryLineItems JournalEntryLineItem[]
  subsidiary            Subsidiary?            @relation(fields: [subsidiaryId], references: [id])
  currency              Currency?              @relation(fields: [currencyId], references: [id])

  @@index([userId])
  @@index([subsidiaryId])
  @@index([currencyId])
  @@map("customers")
}

model Contact {
  id                        String   @id @default(cuid())
  contactNumber             String?  @unique
  firstName                 String
  lastName                  String
  email                     String?
  phone                     String?
  address                   String?
  position                  String?
  isPrimaryForCustomer      Boolean  @default(false)
  receivesQuotesSalesOrders Boolean  @default(false)
  receivesInvoices          Boolean  @default(false)
  receivesInvoiceCc         Boolean  @default(false)
  active                    Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  // Relations
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  vendorId   String?
  vendor     Vendor?   @relation(fields: [vendorId], references: [id])
  leads      Lead[]
  userId     String
  user       User      @relation(fields: [userId], references: [id])

  @@index([customerId])
  @@index([vendorId])
  @@index([userId])
  @@map("contacts")
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  status      String    @default("planning")
  inactive    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  userId                String
  user                  User                   @relation(fields: [userId], references: [id])
  tasks                 Task[]
  invoiceLineItems      InvoiceLineItem[]
  billLineItems         BillLineItem[]
  journalEntryLineItems JournalEntryLineItem[]

  @@index([userId])
  @@map("projects")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("todo")
  priority    String    @default("medium")
  dueDate     DateTime?
  inactive    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@index([userId])
  @@map("tasks")
}

model Vendor {
  id           String   @id @default(cuid())
  vendorNumber String?  @unique
  name         String
  email        String?
  phone        String?
  address      String?
  taxId        String?
  subsidiaryId String?
  currencyId   String?
  inactive     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  requisitions          Requisition[]
  purchaseOrders        PurchaseOrder[]
  bills                 Bill[]
  billCredits           BillCredit[]
  contacts              Contact[]
  preferredItems        Item[]
  journalEntryLineItems JournalEntryLineItem[]
  subsidiary            Subsidiary?            @relation(fields: [subsidiaryId], references: [id])
  currency              Currency?              @relation(fields: [currencyId], references: [id])

  @@index([subsidiaryId])
  @@index([currencyId])
  @@map("vendors")
}

model Department {
  id                    String   @id @default(cuid())
  name                  String
  departmentId          String   @unique @map("code")
  departmentNumber      String?  @unique
  description           String?
  division              String?
  includeChildren       Boolean  @default(false)
  planningCategory      String?
  parentDepartmentId    String?
  costCenterCode        String?
  departmentType        String?
  segmentReportingGroup String?
  sharedServicesFlag    Boolean  @default(false)
  active                Boolean  @default(true)
  managerEmployeeId     String?  @map("managerId")
  approverEmployeeId    String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  users                  User[]
  requisitions           Requisition[]
  employees              Employee[]
  invoiceLineItems       InvoiceLineItem[]
  billLineItems          BillLineItem[]
  journalEntryLineItems  JournalEntryLineItem[]
  items                  Item[]
  departmentSubsidiaries DepartmentSubsidiary[]
  parentDepartment       Department?            @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  childDepartments       Department[]           @relation("DepartmentHierarchy")
  manager                Employee?              @relation("DepartmentManager", fields: [managerEmployeeId], references: [id])
  approver               Employee?              @relation("DepartmentApprover", fields: [approverEmployeeId], references: [id])

  @@index([parentDepartmentId])
  @@index([managerEmployeeId])
  @@index([approverEmployeeId])
  @@map("departments")
}

model DepartmentSubsidiary {
  id           String   @id @default(cuid())
  departmentId String
  subsidiaryId String
  createdAt    DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  subsidiary Subsidiary @relation(fields: [subsidiaryId], references: [id], onDelete: Cascade)

  @@unique([departmentId, subsidiaryId])
  @@index([departmentId])
  @@index([subsidiaryId])
  @@map("department_subsidiaries")
}

model Location {
  id                     String   @id @default(cuid())
  locationId             String   @unique
  name                   String
  code                   String   @unique
  address                String?
  parentLocationId       String?
  subsidiaryId           String?
  locationType           String?
  makeInventoryAvailable Boolean  @default(true)
  inactive               Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  parentLocation       Location?  @relation("LocationHierarchy", fields: [parentLocationId], references: [id], onDelete: SetNull)
  childLocations       Location[] @relation("LocationHierarchy")
  subsidiary           Subsidiary?    @relation("LocationSubsidiary", fields: [subsidiaryId], references: [id], onDelete: SetNull)
  employees             Employee[]
  items                 Item[]
  invoiceLineItems      InvoiceLineItem[]
  billLineItems         BillLineItem[]
  journalEntryLineItems JournalEntryLineItem[]

  @@index([parentLocationId])
  @@index([subsidiaryId])
  @@map("locations")
}

model CostCenter {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  inactive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cost_centers")
}

model ChartOfAccounts {
  id                           String   @id @default(cuid())
  accountId                    String   @unique
  accountNumber                String   @unique @map("accountNumber")
  name                         String
  description                  String?
  accountType                  String // List/select value (Asset, Liability, Equity, Revenue, Expense, etc.)
  normalBalance                String?
  financialStatementSection    String?
  financialStatementGroup      String?
  financialStatementCategory   String?
  inventory                    Boolean  @default(false)
  revalueOpenBalance           Boolean  @default(false)
  eliminateIntercoTransactions Boolean  @default(false)
  summary                      Boolean  @default(false)
  isPosting                    Boolean  @default(true)
  isControlAccount             Boolean  @default(false)
  allowsManualPosting          Boolean  @default(true)
  requiresSubledgerType        String?
  cashFlowCategory             String?
  parentSubsidiaryId           String?
  parentAccountId              String?
  closeToAccountId             String?
  includeChildren              Boolean  @default(false)
  category                     String?
  active                       Boolean  @default(true)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  // Relations
  journalEntryLineItems        JournalEntryLineItem[]
  parentSubsidiary             Subsidiary?                    @relation("ChartOfAccountParentSubsidiary", fields: [parentSubsidiaryId], references: [id])
  subsidiaryAssignments        ChartOfAccountSubsidiary[]
  parentAccount                ChartOfAccounts?           @relation("ChartOfAccountsHierarchy", fields: [parentAccountId], references: [id])
  childAccounts                ChartOfAccounts[]          @relation("ChartOfAccountsHierarchy")
  closeToAccount               ChartOfAccounts?           @relation("ChartOfAccountsCloseTo", fields: [closeToAccountId], references: [id])
  closingSourceAccounts        ChartOfAccounts[]          @relation("ChartOfAccountsCloseTo")
  incomeItems                  Item[]                     @relation("ItemIncomeAccount")
  deferredRevenueItems         Item[]                     @relation("ItemDeferredRevenueAccount")
  inventoryItems               Item[]                     @relation("ItemInventoryAccount")
  cogsExpenseItems             Item[]                     @relation("ItemCogsExpenseAccount")
  deferredCostItems            Item[]                     @relation("ItemDeferredCostAccount")
  retainedEarningsSubsidiaries     Subsidiary[] @relation("SubsidiaryRetainedEarningsAccount")
  ctaSubsidiaries                  Subsidiary[] @relation("SubsidiaryCtaAccount")
  intercompanyClearingSubsidiaries Subsidiary[] @relation("SubsidiaryIntercompanyClearingAccount")
  dueToSubsidiaries                Subsidiary[] @relation("SubsidiaryDueToAccount")
  dueFromSubsidiaries              Subsidiary[] @relation("SubsidiaryDueFromAccount")

  @@index([parentSubsidiaryId])
  @@index([parentAccountId])
  @@index([closeToAccountId])
  @@map("chart_of_accounts")
}

model ChartOfAccountSubsidiary {
  id               String   @id @default(cuid())
  chartOfAccountId String
  subsidiaryId     String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  chartOfAccount ChartOfAccounts @relation(fields: [chartOfAccountId], references: [id], onDelete: Cascade)
  subsidiary Subsidiary          @relation("ChartOfAccountSubsidiaryAssignment", fields: [subsidiaryId], references: [id], onDelete: Cascade)

  @@unique([chartOfAccountId, subsidiaryId])
  @@index([subsidiaryId])
  @@map("chart_of_account_subsidiaries")
}

model CustomFieldDefinition {
  id           String   @id @default(cuid())
  name         String
  label        String
  type         String // text, number, date, select, etc.
  required     Boolean  @default(false)
  defaultValue String?
  options      String? // JSON for select options
  entityType   String // Customer, Order, etc.
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  values CustomFieldValue[]

  @@map("custom_field_definitions")
}

model CustomFieldValue {
  id         String   @id @default(cuid())
  fieldId    String
  recordId   String // ID of the record
  entityType String // Type of Subsidiary
  value      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  field CustomFieldDefinition @relation(fields: [fieldId], references: [id])

  @@index([fieldId])
  @@index([entityType, recordId])
  @@map("custom_field_values")
}

model CustomTransactionType {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  entityType  String // Quote, Order, Invoice, etc.
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("custom_transaction_types")
}

model Lead {
  id              String    @id @default(cuid())
  leadNumber      String?   @unique
  firstName       String?
  lastName        String?
  email           String?
  phone           String?
  company         String?
  title           String?
  website         String?
  industry        String?
  address         String?
  status          String    @default("new")
  source          String?
  rating          String?
  notes           String?
  expectedValue   Decimal? @db.Decimal(18, 2)
  qualifiedAt     DateTime?
  convertedAt     DateTime?
  lastContactedAt DateTime?
  inactive        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  subsidiaryId  String?
  subsidiary    Subsidiary?  @relation(fields: [subsidiaryId], references: [id])
  currencyId    String?
  currency      Currency?    @relation(fields: [currencyId], references: [id])
  customerId    String?
  customer      Customer?    @relation(fields: [customerId], references: [id])
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([subsidiaryId])
  @@index([currencyId])
  @@index([customerId])
  @@index([contactId])
  @@index([opportunityId])
  @@map("leads")
}

model Opportunity {
  id                String    @id @default(cuid())
  opportunityNumber String?   @unique
  name              String
  amount            Decimal? @db.Decimal(18, 2)
  stage             String    @default("prospecting")
  closeDate         DateTime?
  probability       Float?
  subsidiaryId      String?
  currencyId        String?
  inactive          Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  customerId String
  customer   Customer              @relation(fields: [customerId], references: [id])
  leads      Lead[]
  userId     String
  user       User                  @relation(fields: [userId], references: [id])
  quote      Quote?
  lineItems  OpportunityLineItem[]
  subsidiary Subsidiary?               @relation(fields: [subsidiaryId], references: [id])
  currency   Currency?             @relation(fields: [currencyId], references: [id])

  @@index([customerId])
  @@index([userId])
  @@index([subsidiaryId])
  @@index([currencyId])
  @@map("opportunities")
}

model OpportunityLineItem {
  id          String   @id @default(cuid())
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @default(0) @db.Decimal(18, 2)
  lineTotal   Decimal  @default(0) @db.Decimal(18, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  itemId        String?
  item          Item?       @relation(fields: [itemId], references: [id])

  @@index([opportunityId])
  @@index([itemId])
  @@map("opportunity_line_items")
}

model Quote {
  id         String    @id @default(cuid())
  number     String    @unique
  status     String    @default("draft")
  total      Decimal   @db.Decimal(18, 2)
  validUntil DateTime?
  notes      String?
  subsidiaryId String?
  currencyId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  customerId    String
  customer      Customer        @relation(fields: [customerId], references: [id])
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  opportunityId String?         @unique
  opportunity   Opportunity?    @relation(fields: [opportunityId], references: [id])
  salesOrder    SalesOrder?
  lineItems     QuoteLineItem[]
  subsidiary    Subsidiary?     @relation(fields: [subsidiaryId], references: [id])
  currency      Currency?       @relation(fields: [currencyId], references: [id])

  @@index([customerId])
  @@index([userId])
  @@index([subsidiaryId])
  @@index([currencyId])
  @@map("quotes")
}

model SalesOrder {
  id         String   @id @default(cuid())
  number     String   @unique
  status     String   @default("draft")
  total      Decimal   @db.Decimal(18, 2)
  subsidiaryId String?
  currencyId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  customerId   String
  customer     Customer             @relation(fields: [customerId], references: [id])
  userId       String
  user         User                 @relation(fields: [userId], references: [id])
  quoteId      String?              @unique
  quote        Quote?               @relation(fields: [quoteId], references: [id])
  invoices     Invoice[]
  lineItems    SalesOrderLineItem[]
  fulfillments Fulfillment[]
  subsidiary   Subsidiary?          @relation(fields: [subsidiaryId], references: [id])
  currency     Currency?            @relation(fields: [currencyId], references: [id])

  @@index([customerId])
  @@index([userId])
  @@index([subsidiaryId])
  @@index([currencyId])
  @@map("sales_orders")
}

model Invoice {
  id         String    @id @default(cuid())
  number     String    @unique
  status     String    @default("draft")
  total      Decimal   @db.Decimal(18, 2)
  dueDate    DateTime?
  paidDate   DateTime?
  subsidiaryId String?
  currencyId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  customerId   String
  customer     Customer          @relation(fields: [customerId], references: [id])
  salesOrderId String?
  salesOrder   SalesOrder?       @relation(fields: [salesOrderId], references: [id])
  userId       String?
  user         User?             @relation(fields: [userId], references: [id])
  cashReceipts CashReceipt[]
  lineItems    InvoiceLineItem[]
  creditMemos  CreditMemo[]
  subsidiary   Subsidiary?       @relation(fields: [subsidiaryId], references: [id])
  currency     Currency?         @relation(fields: [currencyId], references: [id])

  @@index([customerId])
  @@index([salesOrderId])
  @@index([userId])
  @@index([subsidiaryId])
  @@index([currencyId])
  @@map("invoices")
}

model CashReceipt {
  id        String   @id @default(cuid())
  number    String?  @unique
  amount    Decimal   @db.Decimal(18, 2)
  date      DateTime
  method    String // check, wire, etc.
  reference String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("cash_receipts")
}

model Requisition {
  id           String    @id @default(cuid())
  number       String    @unique
  status       String    @default("draft")
  title        String?
  description  String?
  priority     String    @default("medium")
  neededByDate DateTime?
  notes        String?
  total        Decimal   @default(0) @db.Decimal(18, 2)
  subsidiaryId String?
  currencyId   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  userId        String
  user          User                  @relation(fields: [userId], references: [id])
  departmentId  String?
  department    Department?           @relation(fields: [departmentId], references: [id])
  vendorId      String?
  vendor        Vendor?               @relation(fields: [vendorId], references: [id])
  subsidiary    Subsidiary?               @relation(fields: [subsidiaryId], references: [id])
  currency      Currency?             @relation(fields: [currencyId], references: [id])
  lineItems     RequisitionLineItem[]
  purchaseOrder PurchaseOrder?

  @@index([userId])
  @@index([departmentId])
  @@index([vendorId])
  @@index([subsidiaryId])
  @@index([currencyId])
  @@index([status])
  @@map("requisitions")
}

model RequisitionLineItem {
  id          String   @id @default(cuid())
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @default(0) @db.Decimal(18, 2)
  lineTotal   Decimal  @default(0) @db.Decimal(18, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requisitionId String
  requisition   Requisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  itemId        String?
  item          Item?       @relation(fields: [itemId], references: [id])

  @@index([requisitionId])
  @@index([itemId])
  @@map("requisition_line_items")
}

model PurchaseOrder {
  id         String   @id @default(cuid())
  number     String   @unique
  status     String   @default("draft")
  total      Decimal   @db.Decimal(18, 2)
  subsidiaryId String?
  currencyId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  vendorId      String
  vendor        Vendor                  @relation(fields: [vendorId], references: [id])
  userId        String
  user          User                    @relation(fields: [userId], references: [id])
  requisitionId String?                 @unique
  requisition   Requisition?            @relation(fields: [requisitionId], references: [id])
  lineItems     PurchaseOrderLineItem[]
  receipts      Receipt[]
  bills         Bill[]
  subsidiary    Subsidiary?                 @relation(fields: [subsidiaryId], references: [id])
  currency      Currency?               @relation(fields: [currencyId], references: [id])

  @@index([vendorId])
  @@index([userId])
  @@index([subsidiaryId])
  @@index([currencyId])
  @@map("purchase_orders")
}

model PurchaseOrderLineItem {
  id           String   @id @default(cuid())
  description  String
  quantity     Int
  unitPrice    Decimal  @db.Decimal(18, 2)
  lineTotal    Decimal  @db.Decimal(18, 2)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

