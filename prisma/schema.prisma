  consolidationMethod           String?
  ownershipPercent              Float?
  retainedEarningsAccountId     String?
  ctaAccountId                  String?
  intercompanyClearingAccountId String?
  dueToAccountId                String?
  dueFromAccountId              String?
  periodLockDate                DateTime?
  active                        Boolean   @default(true)
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  // Relations
  defaultCurrencyId           String?
  defaultCurrency             Currency?                  @relation("SubsidiaryDefaultCurrency", fields: [defaultCurrencyId], references: [id])
  functionalCurrency          Currency?                  @relation("SubsidiaryFunctionalCurrency", fields: [functionalCurrencyId], references: [id])
  reportingCurrency           Currency?                  @relation("SubsidiaryReportingCurrency", fields: [reportingCurrencyId], references: [id])
  parentSubsidiary            Subsidiary?                @relation("SubsidiaryHierarchy", fields: [parentSubsidiaryId], references: [id])
  childSubsidiaries           Subsidiary[]               @relation("SubsidiaryHierarchy")
