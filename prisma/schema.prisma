  @@map("rev_rec_templates")
}

model Employee {
  id                        String    @id @default(cuid())
  employeeId                String?   @unique @map("employeeNumber")
  eid                       String?   @unique
  firstName                 String
  lastName                  String
  displayName               String?
  email                     String?   @unique
  phone                     String?
  title                     String?
  status                    String    @default("active")
  active                    Boolean   @default(true)
  includeChildren           Boolean   @default(false)
  hireDate                  DateTime?
  terminationDate           DateTime?
  locationId                String?
  approverEmployeeId        String?
  expenseApproverEmployeeId String?
  billableFlag              Boolean   @default(false)
  laborType                 String?
  laborCostRate             Decimal? @db.Decimal(18, 2)
  billingRate               Decimal? @db.Decimal(18, 2)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  // Relations
  subsidiaryId             String?
  subsidiary               Subsidiary?            @relation(fields: [subsidiaryId], references: [id])
  employeeSubsidiaries     EmployeeSubsidiary[]
  departmentId             String?
  departmentRef            Department?            @relation(fields: [departmentId], references: [id])
  location                 Location?              @relation(fields: [locationId], references: [id])
  userId                   String?                @unique
  user                     User?                  @relation(fields: [userId], references: [id])
  managerId                String?
  manager                  Employee?              @relation("EmployeeManager", fields: [managerId], references: [id])
  directReports            Employee[]             @relation("EmployeeManager")
  approver                 Employee?              @relation("EmployeeApprover", fields: [approverEmployeeId], references: [id])
  approvedEmployees        Employee[]             @relation("EmployeeApprover")
  expenseApprover          Employee?              @relation("EmployeeExpenseApprover", fields: [expenseApproverEmployeeId], references: [id])
  expenseApprovedEmployees Employee[]             @relation("EmployeeExpenseApprover")
  postedJournalEntries     JournalEntry[]         @relation("JournalEntryPostedByEmployee")
  approvedJournalEntries   JournalEntry[]         @relation("JournalEntryApprovedByEmployee")
  journalEntryLineItems    JournalEntryLineItem[]
  managedDepartments       Department[]           @relation("DepartmentManager")
  approvedDepartments      Department[]           @relation("DepartmentApprover")

  @@index([subsidiaryId])
  @@index([departmentId])
  @@index([locationId])
  @@index([managerId])
  @@index([approverEmployeeId])
  @@index([expenseApproverEmployeeId])
  @@map("employees")
}

model EmployeeSubsidiary {
  id           String   @id @default(cuid())
  employeeId   String
  subsidiaryId String
  createdAt    DateTime @default(now())

  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  subsidiary Subsidiary @relation(fields: [subsidiaryId], references: [id], onDelete: Cascade)

  @@unique([employeeId, subsidiaryId])
  @@index([employeeId])
  @@index([subsidiaryId])
  @@map("employee_subsidiaries")
}

model Fulfillment {
  id           String   @id @default(cuid())
  number       String   @unique
  status       String   @default("pending")
  date         DateTime @default(now())
  notes        String?
  subsidiaryId String?
  currencyId   String?
  salesOrderId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  salesOrder SalesOrder?       @relation(fields: [salesOrderId], references: [id])
  subsidiary Subsidiary?           @relation(fields: [subsidiaryId], references: [id])
  currency   Currency?         @relation(fields: [currencyId], references: [id])
  lines      FulfillmentLine[]

  @@map("fulfillments")
}

model FulfillmentLine {
  id                   String  @id @default(cuid())
  quantity             Int     @default(1)
  notes                String?
  fulfillmentId        String
  salesOrderLineItemId String?

  fulfillment        Fulfillment         @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
  salesOrderLineItem SalesOrderLineItem? @relation(fields: [salesOrderLineItemId], references: [id])

  @@map("fulfillment_lines")
}

model BillPayment {
  id        String   @id @default(cuid())
  number    String   @unique
  amount    Decimal  @default(0) @db.Decimal(18, 2)
  date      DateTime @default(now())
  method    String?
  reference String?
  status    String   @default("pending")
  notes     String?
  billId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bill Bill @relation(fields: [billId], references: [id])

  @@map("bill_payments")
}
