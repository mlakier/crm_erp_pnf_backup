  dueToAccount                ChartOfAccounts?           @relation("SubsidiaryDueToAccount", fields: [dueToAccountId], references: [id])
  dueFromAccount              ChartOfAccounts?           @relation("SubsidiaryDueFromAccount", fields: [dueFromAccountId], references: [id])
  departmentAssignments       DepartmentSubsidiary[]
  itemAssignments             ItemSubsidiary[]
  employeeAssignments         EmployeeSubsidiary[]
  userAssignments             UserSubsidiary[]
  defaultForUsers             User[]                    @relation("UserDefaultSubsidiary")
  locations                   Location[]                 @relation("LocationSubsidiary")
  employees                   Employee[]
  items                       Item[]
  customers                   Customer[]
  vendors                     Vendor[]
  leads                       Lead[]
  opportunities               Opportunity[]
  quotes                      Quote[]
  salesOrders                 SalesOrder[]
  invoices                    Invoice[]
  creditMemos                 CreditMemo[]
  purchaseOrders              PurchaseOrder[]
  bills                       Bill[]
  billCredits                 BillCredit[]
  requisitions                Requisition[]
  journalEntries              JournalEntry[]
  journalEntryLineItems       JournalEntryLineItem[]
  accountingPeriods           AccountingPeriod[]
  chartOfAccountsAsParent     ChartOfAccounts[]          @relation("ChartOfAccountParentSubsidiary")
  chartOfAccountAssignments   ChartOfAccountSubsidiary[] @relation("ChartOfAccountSubsidiaryAssignment")
  fulfillments                Fulfillment[]

  @@index([defaultCurrencyId])
  @@index([functionalCurrencyId])
  @@index([reportingCurrencyId])
  @@index([parentSubsidiaryId])
  @@index([retainedEarningsAccountId])
  @@index([ctaAccountId])
  @@index([intercompanyClearingAccountId])
  @@index([dueToAccountId])
  @@index([dueFromAccountId])
  @@map("subsidiaries")
